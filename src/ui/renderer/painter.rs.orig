use gpui::*;
use typst::layout::{Frame, FrameItem};
use typst::syntax::Source;
use crate::ui::renderer::geometry::PT_TO_PX;

fn is_math_placeholder(linked_node: &typst::syntax::LinkedNode) -> bool {
    use typst::syntax::SyntaxKind;
    if linked_node.text() != "?" {
        return false;
    }
    let mut curr = Some(linked_node.clone());
    while let Some(node) = curr {
        if node.kind() == SyntaxKind::Math || node.kind() == SyntaxKind::MathIdent {
            return true;
        }
        curr = node.parent().cloned();
    }
    false
}

pub fn build_span_cache(
    doc: &typst::layout::PagedDocument,
    source: &Source,
) -> std::collections::HashMap<typst::syntax::Span, (usize, bool, bool)> {
    let mut cache = std::collections::HashMap::new();
    for page in &doc.pages {
        collect_spans_rec(&page.frame, source, &mut cache);
    }
    cache
}

fn collect_spans_rec(
    frame: &Frame,
    source: &Source,
    cache: &mut std::collections::HashMap<typst::syntax::Span, (usize, bool, bool)>,
) {
    for (_, item) in frame.items() {
        match item {
            FrameItem::Text(text_item) => {
                for glyph in &text_item.glyphs {
                    let span = glyph.span.0;
                    if !span.is_detached() && !cache.contains_key(&span) {
                        if let Some(node) = source.find(span) {
                            let offset = node.offset();
                            let is_ph = is_math_placeholder(&node);
                            
                            let node_text = &source.text()[node.range()];
                            let is_integral = node_text.contains("integral")
                                || node_text.contains("int")
                                || node_text.contains('∫')
                                || node_text.contains('∬')
                                || node_text.contains('∭')
                                || node_text.contains('∮');
                            
                            let is_radical_node = node_text.contains("sqrt")
                                || node_text.contains("root")
                                || node_text.contains('√')
                                || node_text.contains('∛')
                                || node_text.contains('∜');
                            
                            let is_rad = is_radical_node || is_integral;
                            cache.insert(span, (offset, is_ph, is_rad));
                        }
                    }
                }
            }
            FrameItem::Group(group) => {
                collect_spans_rec(&group.frame, source, cache);
            }
            _ => {}
        }
    }
}

// Recursive helper to traverse and render nested Typst Frame items natively inside GPUI
pub fn paint_frame(
    frame: &Frame,
    origin: Point<Pixels>,
    window: &mut Window,
    cx: &mut App,
    source: &Source,
    selection_range: Option<(usize, usize)>,
    zoom: f32,
    show_glyph_boxes: bool,
    span_cache: Option<&std::collections::HashMap<typst::syntax::Span, (usize, bool, bool)>>,
) {
    let mut font_cache: std::collections::HashMap<u64, FontId> = std::collections::HashMap::new();
    paint_frame_rec(
        frame,
        origin,
        origin.y,
        window,
        cx,
        source,
        selection_range,
        zoom,
        show_glyph_boxes,
        span_cache,
        &mut font_cache,
    );
}

fn paint_frame_rec(
    frame: &Frame,
    origin: Point<Pixels>,
    parent_baseline: Pixels,
    window: &mut Window,
    cx: &mut App,
    source: &Source,
    selection_range: Option<(usize, usize)>,
    zoom: f32,
    show_glyph_boxes: bool,
    span_cache: Option<&std::collections::HashMap<typst::syntax::Span, (usize, bool, bool)>>,
    font_cache: &mut std::collections::HashMap<u64, FontId>,
) {
    // Discover the local baseline by finding the max of text items in this frame
    let mut local_baseline = parent_baseline;
    for (pos, item) in frame.items() {
        if let FrameItem::Text(_text_item) = item {
            let item_y = origin.y + px(pos.y.to_pt() as f32 * PT_TO_PX) * zoom;
            local_baseline = local_baseline.max(item_y);
        }
    }

    for (pos, item) in frame.items() {
        let item_x = origin.x + px(pos.x.to_pt() as f32 * PT_TO_PX) * zoom;
        let item_y = origin.y + px(pos.y.to_pt() as f32 * PT_TO_PX) * zoom;

        match item {
            FrameItem::Text(text_item) => {
                let size_px = px(text_item.size.to_pt() as f32 * PT_TO_PX) * zoom;
                
                // Map Typst text paint color directly to hardware accelerated color
                let text_color = match &text_item.fill {
                    typst::visualize::Paint::Solid(color) => {
                        let rgb = color.to_rgb();
                        gpui::Rgba {
                            r: rgb.red,
                            g: rgb.green,
                            b: rgb.blue,
                            a: rgb.alpha,
                        }
                    }
                    _ => gpui::Rgba { r: 0.0, g: 0.0, b: 0.0, a: 1.0 },
                };

                // ── Font resolution ──────────────────────────────────────────────────────
                // Use data_ptr as the per-frame local cache key (fast: no string ops on
                // repeated glyphs from the same face). On first miss, look up the global
                // PostScript-name registry built at startup — PS names are globally unique
                // by spec and stable regardless of which Arc<[u8]> holds the bytes.
                let font_id = {
                    let data_ptr = text_item.font.ttf().raw_face().data.as_ptr() as u64;
                    if let Some(&id) = font_cache.get(&data_ptr) {
                        id
                    } else {
                        let id = crate::ui::resolve_typst_font(cx, &text_item.font).unwrap();
                        font_cache.insert(data_ptr, id);
                        id
                    }
                };
                let hsla_color: gpui::Hsla = text_color.into();

                let mut current_x = item_x;
                for glyph in &text_item.glyphs {
                    let x_offset = px((glyph.x_offset.get() as f32) * (text_item.size.to_pt() as f32) * PT_TO_PX) * zoom;
                    let y_offset = px((glyph.y_offset.get() as f32) * (text_item.size.to_pt() as f32) * PT_TO_PX) * zoom;
                    let x_advance = px((glyph.x_advance.get() as f32) * (text_item.size.to_pt() as f32) * PT_TO_PX) * zoom;
                    
                    let span = glyph.span.0;
                    let mut is_placeholder = false;
                    let mut is_glyph_selected = false;
                    let mut is_radical = false;
                    
                    let mut has_cached = false;
                    if let Some(cache) = span_cache {
                        if let Some(&(offset, is_ph, is_rad)) = cache.get(&span) {
                            is_placeholder = is_ph;
                            is_radical = is_rad;
                            has_cached = true;
                            
                            if let Some((sel_start, sel_end)) = selection_range {
                                let glyph_offset = offset + (glyph.span.1 as usize);
                                let min = sel_start.min(sel_end);
                                let max = sel_start.max(sel_end);
                                if glyph_offset >= min && glyph_offset < max {
                                    is_glyph_selected = true;
                                }
                            }
                        }
                    }
                    
                    if !has_cached {
                        let linked_node = source.find(span);
                        if let Some(ref node) = linked_node {
                            is_placeholder = is_math_placeholder(node);
                            
                            if let Some((sel_start, sel_end)) = selection_range {
                                let offset = node.offset() + (glyph.span.1 as usize);
                                let min = sel_start.min(sel_end);
                                let max = sel_start.max(sel_end);
                                if offset >= min && offset < max {
                                    is_glyph_selected = true;
                                }
                            }
                        }

                        if let Some(ref node) = linked_node {
                            let node_text = &source.text()[node.range()];
                            let is_integral = node_text.contains("integral")
                                || node_text.contains("int")
                                || node_text.contains('∫')
                                || node_text.contains('∬')
                                || node_text.contains('∭')
                                || node_text.contains('∮');
                            
                            let is_radical_node = node_text.contains("sqrt")
                                || node_text.contains("root")
                                || node_text.contains('√')
                                || node_text.contains('∛')
                                || node_text.contains('∜');
                            
                            is_radical = is_radical_node || is_integral;
                        }
                    }

                    // Uniform selection highlight bounds across the same line/shift
                    let mut sel_box_top = item_y - y_offset - size_px * 0.95;
                    let mut sel_box_height = size_px * 1.25;

                    if is_radical {
                        let face = text_item.font.ttf();
                        let units_per_em = face.units_per_em();
                        let scale = size_px / f32::from(units_per_em);
                        if let Some(rect) = face.glyph_bounding_box(ttf_parser::GlyphId(glyph.id)) {
                            let y_max = f32::from(rect.y_max) * scale;
                            let y_min = f32::from(rect.y_min) * scale;
                            sel_box_top = item_y - y_offset - y_max;
                            sel_box_height = (y_max - y_min).max(size_px * 0.5);
                        }
                    }

                    if show_glyph_boxes {
                        let mut adjusted_box_top = item_y - y_offset - size_px;
                        let mut box_height = size_px * 1.5;

                        if is_radical {
                            let face = text_item.font.ttf();
                            let units_per_em = face.units_per_em();
                            let scale = size_px / f32::from(units_per_em);
                            if let Some(rect) = face.glyph_bounding_box(ttf_parser::GlyphId(glyph.id)) {
                                let y_max = f32::from(rect.y_max) * scale;
                                let y_min = f32::from(rect.y_min) * scale;
                                adjusted_box_top = item_y - y_offset - y_max;
                                box_height = (y_max - y_min).max(size_px * 0.5);
                            }
                        }

                        // Debug glyph boxes (matching 1.0/0.5 split and y_offset in geometry.rs)
                        window.paint_quad(quad(
                            Bounds {
                                origin: point(current_x + x_offset, adjusted_box_top),
                                size: size(x_advance, box_height),
                            },
                            px(0.0),
                            gpui::rgba(0xff000011), // Very light red fill
                            px(0.5) * zoom,
                            gpui::rgba(0xff000088), // 50% red border
                            Default::default(),
                        ));
                    }

                    if is_placeholder {
                        if is_glyph_selected {
                            // Draw translucent vector selection box behind the placeholder, consistent with text selection
                            window.paint_quad(quad(
                                Bounds {
                                    origin: point(current_x, sel_box_top),
                                    size: size(x_advance, sel_box_height),
                                },
                                px(0.0),
                                gpui::rgba(0x3b82f633), // 20% opacity Blue-500 selection highlight
                                px(0.0),
                                gpui::transparent_black(),
                                Default::default(),
                            ));
                        }

                        // Design a beautiful rounded box representing the slot
                        let box_height_ph = size_px * 0.70;
                        let box_width_ph = size_px * 0.70;
                        let box_y_ph = item_y - size_px * 0.75;
                        let bounds = Bounds {
                            origin: point(current_x + (x_advance - box_width_ph) / 2.0, box_y_ph),
                            size: size(box_width_ph, box_height_ph),
                        };

                        // Unselected (and selected) look: Soft gray border with a light background representing the placeholder
                        window.paint_quad(quad(
                            bounds,
                            px(2.5) * zoom,
                            gpui::rgba(0x00000008), // 3% dark fill
                            px(1.0) * zoom,
                            gpui::rgba(0x9ca3af80), // 50% opacity gray-400 border
                            Default::default(),
                        ));
                    } else {
                        // Vector Selection Box Overlay rendering (if selection exists)
                        if is_glyph_selected {
                            // Draw translucent vector selection box behind the glyph
                            window.paint_quad(quad(
                                Bounds {
                                    origin: point(current_x, sel_box_top),
                                    size: size(x_advance, sel_box_height),
                                },
                                px(0.0),
                                gpui::rgba(0x3b82f633), // 20% opacity Blue-500 selection highlight
                                px(0.0),
                                gpui::transparent_black(),
                                Default::default(),
                            ));
                        }

                        // Construct GPUI GlyphId from Typst's shaped glyph ID using transmute
                        let gpui_glyph_id: gpui::GlyphId = unsafe { std::mem::transmute(glyph.id as u32) };
                        
                        // Paint glyph directly at Typst's exact coordinate!
                        // Note: Typst's baseline is item_y. Typst's y_offset goes UP, so we subtract y_offset.
                        let glyph_origin = point(current_x + x_offset, item_y - y_offset);
                        
                        let _ = window.paint_glyph(
                            glyph_origin,
                            font_id,
                            gpui_glyph_id,
                            size_px,
                            hsla_color,
                        );
                    }

                    current_x += x_advance;
                }
            }
            FrameItem::Group(group) => {
                let dx = px(group.transform.tx.to_pt() as f32 * PT_TO_PX) * zoom;
                let dy = px(group.transform.ty.to_pt() as f32 * PT_TO_PX) * zoom;
                paint_frame_rec(
                    &group.frame,
                    point(item_x + dx, item_y + dy),
                    item_y,
                    window,
                    cx,
                    source,
                    selection_range,
                    zoom,
                    show_glyph_boxes,
                    span_cache,
                    font_cache,
                );
            }
            FrameItem::Shape(shape, _) => {
                let geometry = &shape.geometry;

                // Extract high-performance custom fills and strokes
                let fill_color = match &shape.fill {
                    Some(typst::visualize::Paint::Solid(color)) => {
                        let rgb = color.to_rgb();
                        gpui::Rgba {
                            r: rgb.red,
                            g: rgb.green,
                            b: rgb.blue,
                            a: rgb.alpha,
                        }
                    }
                    _ => gpui::Rgba { r: 0.0, g: 0.0, b: 0.0, a: 0.0 },
                };

                let stroke_color = match &shape.stroke {
                    Some(stroke) => match &stroke.paint {
                        typst::visualize::Paint::Solid(color) => {
                            let rgb = color.to_rgb();
                            gpui::Rgba {
                                r: rgb.red,
                                g: rgb.green,
                                b: rgb.blue,
                                a: rgb.alpha,
                            }
                        }
                        _ => gpui::Rgba { r: 0.0, g: 0.0, b: 0.0, a: 0.0 },
                    },
                    None => gpui::Rgba { r: 0.0, g: 0.0, b: 0.0, a: 0.0 },
                };

                let stroke_width = match &shape.stroke {
                    Some(stroke) => px(stroke.thickness.to_pt() as f32 * PT_TO_PX) * zoom,
                    None => px(0.0),
                };

                match geometry {
                    typst::visualize::Geometry::Rect(rect_size) => {
                        let rect_w = px(rect_size.x.to_pt() as f32 * PT_TO_PX) * zoom;
                        let rect_h = px(rect_size.y.to_pt() as f32 * PT_TO_PX) * zoom;
                        let rect_bounds = Bounds {
                            origin: point(item_x, item_y),
                            size: size(rect_w, rect_h),
                        };

                        if show_glyph_boxes {
                            window.paint_quad(quad(
                                rect_bounds,
                                px(0.0),
                                gpui::rgba(0x00ff0011), // Very light green for shapes
                                px(0.5) * zoom,
                                gpui::rgba(0x00ff0088),
                                Default::default(),
                            ));
                        }

                        window.paint_quad(quad(
                            rect_bounds,
                            px(0.0),
                            fill_color,
                            stroke_width,
                            stroke_color,
                            Default::default(),
                        ));
                    }
                    typst::visualize::Geometry::Line(target_pos) => {
                        let dx = px(target_pos.x.to_pt() as f32 * PT_TO_PX) * zoom;
                        let dy = px(target_pos.y.to_pt() as f32 * PT_TO_PX) * zoom;

                        if show_glyph_boxes {
                            window.paint_quad(quad(
                                Bounds {
                                    origin: point(item_x, item_y),
                                    size: size(dx.abs().max(px(1.0)), dy.abs().max(px(1.0))),
                                },
                                px(0.0),
                                gpui::rgba(0x00ff0011),
                                px(0.5) * zoom,
                                gpui::rgba(0x00ff0088),
                                Default::default(),
                            ));
                        }

                        let end_x = item_x + dx;
                        let end_y = item_y + dy;

                        let mut builder = PathBuilder::stroke(stroke_width);
                        builder.move_to(point(item_x, item_y));
                        builder.line_to(point(end_x, end_y));
                        if let Ok(path) = builder.build() {
                            window.paint_path(path, stroke_color);
                        }
                    }
                    typst::visualize::Geometry::Curve(curve) => {
                        // 1. Draw fill path if fill is present
                        if shape.fill.is_some() {
                            let mut fill_builder = PathBuilder::fill();
                            for item in curve.0.iter() {
                                match item {
                                    typst::visualize::CurveItem::Move(p) => {
                                        let to_x = item_x + px(p.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let to_y = item_y + px(p.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        fill_builder.move_to(point(to_x, to_y));
                                    }
                                    typst::visualize::CurveItem::Line(p) => {
                                        let to_x = item_x + px(p.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let to_y = item_y + px(p.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        fill_builder.line_to(point(to_x, to_y));
                                    }
                                    typst::visualize::CurveItem::Cubic(ctrl1, ctrl2, to) => {
                                        let ctrl1_x = item_x + px(ctrl1.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let ctrl1_y = item_y + px(ctrl1.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let ctrl2_x = item_x + px(ctrl2.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let ctrl2_y = item_y + px(ctrl2.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let to_x = item_x + px(to.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let to_y = item_y + px(to.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        
                                        fill_builder.cubic_bezier_to(
                                            point(to_x, to_y),
                                            point(ctrl1_x, ctrl1_y),
                                            point(ctrl2_x, ctrl2_y),
                                        );
                                    }
                                    typst::visualize::CurveItem::Close => {
                                        fill_builder.close();
                                    }
                                }
                            }
                            if let Ok(path) = fill_builder.build() {
                                window.paint_path(path, fill_color);
                            }
                        }

                        // 2. Draw stroke path if stroke is present
                        if shape.stroke.is_some() {
                            let mut stroke_builder = PathBuilder::stroke(stroke_width);
                            for item in curve.0.iter() {
                                match item {
                                    typst::visualize::CurveItem::Move(p) => {
                                        let to_x = item_x + px(p.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let to_y = item_y + px(p.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        stroke_builder.move_to(point(to_x, to_y));
                                    }
                                    typst::visualize::CurveItem::Line(p) => {
                                        let to_x = item_x + px(p.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let to_y = item_y + px(p.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        stroke_builder.line_to(point(to_x, to_y));
                                    }
                                    typst::visualize::CurveItem::Cubic(ctrl1, ctrl2, to) => {
                                        let ctrl1_x = item_x + px(ctrl1.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let ctrl1_y = item_y + px(ctrl1.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let ctrl2_x = item_x + px(ctrl2.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let ctrl2_y = item_y + px(ctrl2.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let to_x = item_x + px(to.x.to_pt() as f32 * PT_TO_PX) * zoom;
                                        let to_y = item_y + px(to.y.to_pt() as f32 * PT_TO_PX) * zoom;
                                        
                                        stroke_builder.cubic_bezier_to(
                                            point(to_x, to_y),
                                            point(ctrl1_x, ctrl1_y),
                                            point(ctrl2_x, ctrl2_y),
                                        );
                                    }
                                    typst::visualize::CurveItem::Close => {
                                        stroke_builder.close();
                                    }
                                }
                            }
                            if let Ok(path) = stroke_builder.build() {
                                window.paint_path(path, stroke_color);
                            }
                        }
                    }
                }
            }
            _ => {}
        }
    }
}
